# Ejemplo de configuración de secrets para Streamlit Cloud
# Para usar IA contextual con Groq, obtén tu API key GRATIS en: https://console.groq.com
#
# Instrucciones:
# 1. Copia este archivo como .streamlit/secrets.toml
# 2. Reemplaza el valor con tu API key real
# 3. NO compartas ni subas este archivo al repositorio (ya está en .gitignore)

GROQ_API_KEY = "gsk_pon_tu_api_key_aqui"
